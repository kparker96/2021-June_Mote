library(tidyverse)
library(lubridate)
library(readxl)
# Chunk 2
# Code from Ross' acer florida paper github
# making temp profile fig
myTime <- now() %>% floor_date("day")
myData <- tibble(max_temp = c(29, 33, 35, 38),
time = list(seq(myTime, myTime + hm("09:00"), by = "1 min"))) %>%
mutate(set_point = map(max_temp, ~ c(
rep(29, 61),
seq(29, .x, len = 180),
rep(.x, 180),
seq(.x, 29, len = 60),
rep(29, 60)
)))
df <- myData %>% unnest(time, set_point)
ggplot(df, aes(x = time, y = set_point, group = factor(max_temp))) +
geom_rect(aes(xmin = myTime + hm("07:00"), xmax = myTime + hm("09:00"),
ymin = -Inf, ymax = Inf), fill = "lightgray", alpha = 0.99999) +
geom_line(aes(color = set_point), lwd = 1) +
scale_color_gradient2(midpoint=33.5, low="#4575b4", mid="#fee090", high="#d73027") +
scale_x_datetime(breaks = "1 hour", expand = c(0,0),
labels = function(x) difftime(x, myTime + hm("07:00"), units = "hours")) +
labs(x = "Hours from local sunset", y = "Temperature (°C)") +
scale_y_continuous(breaks = seq(29,38, by = 1)) +
annotate("text", x = myTime + hm("08:30"), y = 29.1, angle = 90, adj = 0, size = 5,
label = expression(paste("} /u2013 " , italic(F[V]/F[M]), " measured"))) +
theme_classic() +
theme(text = element_text(size = 20)) +
theme(legend.position = "none") +
ggtitle("CBASS Assay Temperature Profiles") +
theme(plot.title = element_text(hjust = 0.5))
ggsave("ramp_example.png", width = 174, height = 100, units = "mm")
