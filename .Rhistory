library(tidyverse)
library(ggplot2)
library(car)
library(emmeans)
library(multcomp)
library(multcompView) # for cld function
library(writexl)
library(openxlsx)
# TRANSCRIPTOMIC SHIFT DATA #
shift_data_shifted <- read.delim("data/Sequencing/Porites_astreoides/Pilot_Fail_New_Concat_Compiled/shift_data_shifted.txt") %>%
dplyr::mutate(combo_shift = PC1_shift + PC2_shift) %>%
filter(Temp != 30)
# STATS #
# 1. Normality assumption (Shapiro-Wilk test)
# Histogram Visualization
ggplot(shift_data_shifted, aes(x = combo_shift)) +
geom_histogram(binwidth = 20)
shapiro_test <- shapiro.test(shift_data_shifted$combo_shift)
print(shapiro_test)
if (shapiro_test$p.value < 0.05) {
print("The data may not be normally distributed.")
} else {
print("The data appears to be normally distributed.")
}
# 2. Homogeneity of variances (Levene's test)
levene_test <- leveneTest(combo_shift ~ group, data = shift_data_shifted)
print(levene_test)
if (levene_test$`Pr(>F)`[1] < 0.05) {
print("There may be an issue with homogeneity of variances.")
} else {
print("The variances appear to be homogeneous across groups.")
}
# Residuals vs. Fitted plot
model <- aov(combo_shift ~ group, data = shift_data_shifted)
plot(model)
aov(combo_shift ~ group,
data = shift_data_shifted
)
oneway.test(combo_shift ~ group,
data = shift_data_shifted,
var.equal = TRUE # assuming equal variances
)
# Perform Tukey's HSD post hoc test
tukey_result <- TukeyHSD(model)
tukey_table <- as.data.frame(tukey_result$group) %>%
rownames_to_column(var="contrast")
write_xlsx(tukey_table, "tukey_result.xlsx")
# ANOVA and Tukey within Temperature Treatments
#34 C
shift_34 <- shift_data_shifted %>%
filter(Temp == 34)
model_34 <- aov(combo_shift ~ group, data = shift_34)
plot(model_34)
rownames_to_column(var="contrast")
library(tidyverse)
library(ggplot2)
library(car)
library(emmeans)
library(multcomp)
library(multcompView) # for cld function
library(writexl)
library(openxlsx)
# TRANSCRIPTOMIC SHIFT DATA #
shift_data_shifted <- read.delim("data/Sequencing/Porites_astreoides/Pilot_Fail_New_Concat_Compiled/shift_data_shifted.txt") %>%
dplyr::mutate(combo_shift = PC1_shift + PC2_shift) %>%
filter(Temp != 30)
# Histogram Visualization
ggplot(shift_data_shifted, aes(x = combo_shift)) +
geom_histogram(binwidth = 20)
shapiro_test <- shapiro.test(shift_data_shifted$combo_shift)
print(shapiro_test)
if (shapiro_test$p.value < 0.05) {
print("The data may not be normally distributed.")
} else {
print("The data appears to be normally distributed.")
}
# 2. Homogeneity of variances (Levene's test)
levene_test <- leveneTest(combo_shift ~ group, data = shift_data_shifted)
print(levene_test)
if (levene_test$`Pr(>F)`[1] < 0.05) {
print("There may be an issue with homogeneity of variances.")
} else {
print("The variances appear to be homogeneous across groups.")
}
# Residuals vs. Fitted plot
model <- aov(combo_shift ~ group, data = shift_data_shifted)
plot(model)
# Residuals vs. Fitted plot
model <- aov(combo_shift ~ group, data = shift_data_shifted)
plot(model)
qqnorm(resid(model))
qqline(resid(model))
aov(combo_shift ~ group,
data = shift_data_shifted
)
oneway.test(combo_shift ~ group,
data = shift_data_shifted,
var.equal = TRUE # assuming equal variances
)
# Perform Tukey's HSD post hoc test
tukey_result <- TukeyHSD(model)
tukey_table <- as.data.frame(tukey_result$group) %>%
rownames_to_column(var="contrast")
write_xlsx(tukey_table, "tukey_result.xlsx")
# ANOVA and Tukey within Temperature Treatments
#34 C
shift_34 <- shift_data_shifted %>%
filter(Temp == 34)
model_34 <- aov(combo_shift ~ group, data = shift_34)
plot(model_34)
tukey_result_34 <- TukeyHSD(model_34)
tukey_table_34 <- as.data.frame(tukey_result_34$group) %>%
rownames_to_column(var="contrast")
write_xlsx(tukey_table_34, "tukey_result_34.xlsx")
#37 C
shift_37 <- shift_data_shifted %>%
filter(Temp == 37)
#37 C
shift_37 <- shift_data_shifted %>%
filter(Temp == 37)
model_37 <- aov(combo_shift ~ group, data = shift_37)
plot(model_37)
tukey_result_37 <- TukeyHSD(model_37)
tukey_table_37 <- as.data.frame(tukey_result_37$group) %>%
rownames_to_column(var="contrast")
#39 C
shift_39 <- shift_data_shifted %>%
filter(Temp == 39)
model_39 <- aov(combo_shift ~ group, data = shift_39)
tukey_result_39 <- TukeyHSD(model_39)
tukey_table_39 <- as.data.frame(tukey_result_39$group) %>%
rownames_to_column(var="contrast")
emm_34 <- emmeans(model_34, specs = "group")
cld_34 <- cld(emm_34, Letters = letters)
cld_34_subset <- cld_34[, c("group", ".group")]
shift_34_cld <- merge(shift_34, cld_34_subset, by = "group")
shift_34_cld_sum <- shift_34_cld%>%
group_by(Timepoint, Origin) %>%
summarize(.group = unique(.group))
ggplot(shift_34_cld, aes(x = Timepoint, y = combo_shift, fill = Origin)) + #flip order of sites on axis so it goes from lowest to highest ed50
geom_boxplot(aes(fill=Origin)) +
geom_text(data=shift_34_cld %>% distinct(Timepoint, combo_shift, Origin, .group),
aes(label = shift_34_cld_sum$.group))
# Plot Everything
ggplot(shift_data_shifted, aes(x = Origin, y = combo_shift)) + #flip order of sites on axis so it goes from lowest to highest ed50
geom_violin(aes(fill=Origin)) +
scale_fill_manual(labels=c('Inshore', 'Offshore'), values=c('#8ADCE3', "#003A9D")) +
stat_summary(fun = mean, geom = "point", shape = 23, fill = "white") +
labs(y = "Transcriptomic Shift") +
theme_bw() +
facet_grid(Temp~Timepoint, scale = "free") +
ylim(c(0,40)) +
theme(legend.position = "none",
panel.spacing = unit(0, "lines"),
panel.grid.major.x = element_blank(),
panel.grid.minor.x = element_blank(),
panel.grid.minor.y = element_blank(),
panel.grid.major.y = element_blank(),
#panel.border = element_blank(),
axis.text.x = element_blank(),
axis.ticks = element_blank(),
axis.title.y = element_text(size = 18),
axis.title.x = element_blank(),
axis.text.y = element_text(size = 16),
strip.text = element_text(size = 16))
# Plot Everything
ggplot(shift_data_shifted, aes(x = Origin, y = combo_shift)) + #flip order of sites on axis so it goes from lowest to highest ed50
geom_boxplot(aes(fill=Origin)) +
scale_fill_manual(labels=c('Inshore', 'Offshore'), values=c('#8ADCE3', "#003A9D")) +
stat_summary(fun = mean, geom = "point", shape = 23, fill = "white") +
labs(y = "Transcriptomic Shift") +
theme_bw() +
facet_grid(Temp~Timepoint, scale = "free") +
ylim(c(0,40)) +
theme(legend.position = "none",
panel.spacing = unit(0, "lines"),
panel.grid.major.x = element_blank(),
panel.grid.minor.x = element_blank(),
panel.grid.minor.y = element_blank(),
panel.grid.major.y = element_blank(),
#panel.border = element_blank(),
axis.text.x = element_blank(),
axis.ticks = element_blank(),
axis.title.y = element_text(size = 18),
axis.title.x = element_blank(),
axis.text.y = element_text(size = 16),
strip.text = element_text(size = 16))
ggbetweenstats(shift_data_shifted, x = Timepoint, y = combo_shift)
library(ggbetweenstats)
