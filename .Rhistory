axis.ticks = element_blank(),
axis.title.y = element_text(size = 18),
axis.title.x = element_blank(),
axis.text.y = element_text(size = 16),
strip.text = element_text(size = 16))
ggplot(shift_data_shifted, aes(x = combo_shift)) +
geom_histogram(binwidth = 20)
# 2. Normality assumption (Shapiro-Wilk test)
shapiro_test <- shapiro.test(shift_data_shifted$combo_shift)
print("Shapiro-Wilk Normality Test:")
print(shapiro_test)
if (shapiro_test$p.value < 0.05) {
print("The data may not be normally distributed.")
} else {
print("The data appears to be normally distributed.")
}
# 3. Homogeneity of variances (Levene's test)
levene_test <- leveneTest(combo_shift ~ group, data = shift_data_shifted)
library(car)
# 3. Homogeneity of variances (Levene's test)
levene_test <- leveneTest(combo_shift ~ group, data = shift_data_shifted)
print("Levene's Test for Homogeneity of Variance:")
print(levene_test)
if (levene_test$p.value < 0.05) {
print("There may be an issue with homogeneity of variances.")
} else {
print("The variances appear to be homogeneous across groups.")
}
print(levene_test)
# Residuals vs. Fitted plot (optional but useful)
model <- aov(combo_shift ~ group, data = shift_data_shifted)
plot(model)
qqline(resid(model))
aov(combo_shift ~ group,
data = shift_data_shifted
)
oneway.test(combo_shift ~ group,
data = shift_data_shifted,
var.equal = TRUE # assuming equal variances
)
# Perform Tukey's HSD post hoc test
tukey_result <- TukeyHSD(model)
# Check the post hoc results
print(tukey_result)
# Check the post hoc results
tukey <- print(tukey_result)
tukey_result
View(tukey_result)
View(tukey)
# Check the post hoc results
tukey <- as.df(tukey_result)
# Check the post hoc results
tukey <- as.data.frame(tukey_result)
tukey_dataframe <- as.data.frame(tukey_result)
# Assuming 'tukey_result' is the result of TukeyHSD
# Extract the means and differences from the TukeyHSD object
means <- tukey_result$lsmeans
differences <- TukeyHSD(tukey_result)
# Assuming 'tukey_result' is the result of TukeyHSD
# Extract the means and differences from the TukeyHSD object
means <- tukey_result$lsmeans
differences <- TukeyHSD(tukey_result)
# Create a data frame from the extracted information
tukey_dataframe <- data.frame(
Means = means$lsmean,
Lower_CI = means$lower.CL,
Upper_CI = means$upper.CL,
Comparison = rownames(differences)
)
# Perform Tukey's HSD post hoc test
tukey_result <- TukeyHSD(model)
# Assuming 'tukey_result' is the result of TukeyHSD
# Extract the comparison groups and adjusted p-values
comparison <- rownames(tukey_result$lsmeans)
p_values <- tukey_result$lsmeans$'p adj'
# Create a data frame
tukey_dataframe <- data.frame(
Comparison = comparison,
P_Adjusted = p_values
)
View(tukey_dataframe)
view(tukey_dataframe)
tukey_dataframe()
tukey_dataframe
# Extract the TukeyHSD result into a data frame
tukey_dataframe <- as.data.frame(TukeyHSD(tukey_result))
# Assuming your tukey_result is a "multicomp" object
# Access the Tukey's results within the "multicomp" object
tukey_results <- tukey_result$comps
# Convert the Tukey's results to a data frame
tukey_dataframe <- as.data.frame(tukey_results)
# Print the resulting data frame
print(tukey_dataframe)
# Assuming your tukey_result is a "multicomp" object
# Extract the Tukey's results from the "multicomp" object
tukey_results <- tukey_result$comps
# Create an empty data frame to store the results
tukey_dataframe <- data.frame()
# Extract and format the relevant information
for (i in 1:length(tukey_results)) {
comparison <- as.character(tukey_results[[i]]$trt1)
difference <- as.numeric(tukey_results[[i]]$p.adj)
# Add the information to the data frame
tukey_dataframe <- rbind(tukey_dataframe, data.frame(Comparison = comparison, Difference = difference))
}
# Print the resulting data frame
print(tukey_dataframe)
# Perform Tukey's HSD post hoc test
tukey_result <- TukeyHSD(model)
print(tukey_result)
View(tukey_result)
View(tukey_result)
View(tukey_result)
